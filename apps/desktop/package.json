{
  "name": "@amplio/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Amplio desktop app. Local-first product analytics you run yourself.",
  "license": "MIT",
  "author": { "name": "jowpurcinelli", "email": "jppurcinelli@gmail.com" },
  "repository": "https://github.com/jowpurcinelli/amplio",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "bundle": "node build.mjs",
    "dist": "node build.mjs && electron-builder --publish never",
    "typecheck": "node --check src/main.js && node --check src/preload.js && node --check src/lib/serve.js && node --check src/lib/stack.js && node --check src/lib/telemetry.js && node --check src/lib/clickhouse.js && node --check build.mjs",
    "test": "echo \"no desktop tests\""
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  },
  "build": {
    "appId": "com.amplio.desktop",
    "productName": "Amplio",
    "directories": { "buildResources": "assets", "output": "release" },
    "npmRebuild": false,
    "files": ["src/**/*", "package.json"],
    "extraResources": [{ "from": "build", "to": "build" }],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
