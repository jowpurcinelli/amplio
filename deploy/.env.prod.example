# Copy to deploy/.env and fill in. Never commit the real file.

# Domain for automatic HTTPS (Caddy). Use localhost for a local trial.
AMPLIO_DOMAIN=amplio.example.com

# Database secrets (choose strong values).
CLICKHOUSE_PASSWORD=change-me-clickhouse
POSTGRES_PASSWORD=change-me-postgres

# Signs user session tokens (login/signup). REQUIRED in production: the API
# refuses to boot without it, because its built-in dev default is public and
# would let anyone forge tokens. Use a long random value, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-a-long-random-value

# API keys. Comma-separated key:project pairs.
# Write keys are used by SDKs to ingest; read keys drive the dashboard.
AMPLIO_WRITE_KEYS=prod-write-key:default-project
AMPLIO_READ_KEYS=prod-read-key:default-project
