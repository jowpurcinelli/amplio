# Ingest service
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# ClickHouse (matches deploy/docker-compose.yml)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=amplio

# Dev API keys (comma-separated key:project pairs). Defaults to dev-key:dev-project.
AMPLIO_DEV_API_KEYS=dev-key:dev-project

# Flush tuning
FLUSH_MAX_BATCH=1000
FLUSH_MAX_INTERVAL_MS=2000
