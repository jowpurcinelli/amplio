# Ingest service
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# ClickHouse (matches deploy/docker-compose.yml)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=amplio

# Postgres for metadata (API keys, saved charts, dashboards, cohorts).
# When set, write/read keys resolve from the DB. Leave unset to use the env
# key maps below (pure local dev without Postgres).
DATABASE_URL=postgres://amplio:amplio@localhost:5433/amplio

# Fallback API keys used when DATABASE_URL is unset (comma-separated key:project).
AMPLIO_DEV_API_KEYS=dev-key:dev-project
AMPLIO_READ_KEYS=dev-read-key:dev-project

# Flush tuning
FLUSH_MAX_BATCH=1000
FLUSH_MAX_INTERVAL_MS=2000
