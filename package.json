{
  "name": "amplio",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source product analytics. An open Amplitude.",
  "license": "MIT",
  "author": "jowpurcinelli",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "stack:up": "docker compose -f deploy/docker-compose.yml up -d",
    "stack:down": "docker compose -f deploy/docker-compose.yml down"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
